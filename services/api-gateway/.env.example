SERVICE_NAME=api-gateway
PORT=3000
LOG_LEVEL=info

# Redis (rate limiting)
REDIS_HOST=localhost
REDIS_PORT=6379

# Auth
JWT_SECRET=change-me-in-production-use-a-long-random-string

# Upstream service URLs
IDENTITY_SERVICE_URL=http://localhost:3001
TASK_SERVICE_URL=http://localhost:3002
COMMENT_SERVICE_URL=http://localhost:3003
NOTIFICATION_SERVICE_URL=http://localhost:3004
AI_SERVICE_URL=http://localhost:3006
SEARCH_SERVICE_URL=http://localhost:3008
FILE_SERVICE_URL=http://localhost:3005
GOAL_SERVICE_URL=http://localhost:3009
DOCS_SERVICE_URL=http://localhost:3010
AUTOMATIONS_SERVICE_URL=http://localhost:3007
VIEWS_SERVICE_URL=http://localhost:3011
WEBHOOKS_SERVICE_URL=http://localhost:3012
DASHBOARD_SERVICE_URL=http://localhost:3014
SPRINT_SERVICE_URL=http://localhost:3013
SLACK_SERVICE_URL=http://localhost:3015
GITHUB_SERVICE_URL=http://localhost:3016
GITLAB_SERVICE_URL=http://localhost:3017
CHAT_SERVICE_URL=http://localhost:3021
AUDIT_SERVICE_URL=http://localhost:3023

# Database (API key validation)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=clickup
POSTGRES_USER=clickup
POSTGRES_PASSWORD=clickup_dev

# Rate limiting
RATE_LIMIT_MUTATIONS_MAX=250
RATE_LIMIT_MUTATIONS_WINDOW_SECONDS=30
RATE_LIMIT_READS_MAX=1000
RATE_LIMIT_READS_WINDOW_SECONDS=60
